# 이 파일을 .env로 복사하고 실제 값을 채워주세요

# API Configuration
# 백엔드 Spring Boot API
VITE_API_BASE_URL=http://localhost:8081

# Flow API (FastAPI)
VITE_FLOW_API_BASE_URL=http://localhost:8000

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=your-project-id / Supabase 프로젝트 ID. (Supabase를 사용하지 않으면 그대로 두거나 비워 둬도 됩니다.)
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key / Supabase public 키. 클라이언트에서 Supabase에 접근할 때 사용합니다. (미사용 시 기본값 그대로)
VITE_SUPABASE_URL=https://your-project.supabase.co / Supabase 프로젝트 URL

# GOJS License Key
VITE_GOJS_LICENSE=your-gojs-license-key