# ============================================
# Docker/Production Environment Variables
# ============================================
# 이 파일을 .env.docker로 복사하고 실제 값을 채워주세요

# API Configuration
# 백엔드 Spring Boot API
VITE_API_BASE_URL=http://host.docker.internal:8081

# Flow API (FastAPI)
VITE_FLOW_API_BASE_URL=http://host.docker.internal:8000

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_URL=https://your-project.supabase.co

# GOJS License Key
VITE_GOJS_LICENSE=your-gojs-license-key

# Environment
NODE_ENV=production